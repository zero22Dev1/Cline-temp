# Version control internals
.git/

# Dependencies and virtual environments
node_modules/
vendor/
.venv/
venv/
env/

# Build and test outputs
dist/
build/
coverage/
.coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/

# Language and tool caches
**/__pycache__/
**/*.py[cod]
.cache/
.next/
.nuxt/
.parcel-cache/
.turbo/
target/

# Logs and temporary files
**/*.log
**/*.tmp
**/*.temp
**/*.bak
**/*.swp
**/*.swo
**/.DS_Store
tmp/
temp/

# Secrets and local environment files
.env
.env.*
!.env.example
!.env.sample
**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/credentials.json
**/secrets.json

# IDE-local state
.idea/
.vscode/
*.code-workspace

# Office lock and recovery files
**/~$*.xls
**/~$*.xlsx
**/~$*.xlsm
**/~$*.docx
**/~$*.pptx

# Generated scratch data; keep workflow outputs and templates accessible
work/tmp/
work/cache/
